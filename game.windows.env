# 每个服务端单独一个目录名。
# 最终宿主机目录：
# /steam-windows/steamlibrary/steamapps/common/${SERVER_DIR_NAME}
SERVER_DIR_NAME=my-windows-server

# Windows Dedicated Server AppID
STEAM_APP_ID=你的Windows服务端AppID

# Windows-only 服务端通常需要强制拉 Windows depot
STEAMCMD_FORCE_PLATFORM=windows

# 大多数专用服务器可以 anonymous，少数需要 Steam 账号
STEAM_LOGIN=anonymous
# STEAM_USERNAME=
# STEAM_PASSWORD=

# 启动时自动更新
UPDATE_ON_START=1

# 1 表示 validate，稳但慢；正常运行后可以改 0
VALIDATE=0

# wine 或 proton
COMPAT_LAYER=wine

# Wine 基础设置
WINEARCH=win64
WINEDEBUG=-all
WINE_USE_XVFB=1
DISPLAY=:99

# 宿主机普通用户 UID/GID
PUID=1000
PGID=1000

# 单端口映射用
SERVER_PORT=27015

# Windows 服务端 exe，路径相对于服务端安装目录
WIN_SERVER_EXE=DedicatedServer.exe

# Windows 服务端启动参数
WIN_SERVER_ARGS=

# 如果某些游戏需要完全自定义启动命令，可以用 SERVER_COMMAND 覆盖 WIN_SERVER_EXE
# SERVER_COMMAND='wine "/steam/steamlibrary/steamapps/common/my-windows-server/DedicatedServer.exe" -log'

# 可选：启动前执行命令
# PRE_START='ls -lah'

# 可选：把游戏日志文件 tail 到 Docker 前台
# 不是所有游戏都有日志文件；路径相对于服务端安装目录
TAIL_LOG_ON_START=0
TAIL_LOG_PATH=
TAIL_LOG_LINES=80

# 崩溃后自动重启
RESTART_ON_CRASH=1
RESTART_DELAY=10

# 可选：Steam beta 分支
# STEAM_BETA=
# STEAM_BETA_PASSWORD=

# 可选：额外 app_update 参数
# APP_UPDATE_EXTRA=

# Proton 可选：
# 1. docker-compose.windows.yml 打开 /steam-proton:/proton:ro
# 2. COMPAT_LAYER=proton
# 3. PROTON_DIR=/proton/GE-Protonxxx
# PROTON_DIR=/proton/GE-Proton
